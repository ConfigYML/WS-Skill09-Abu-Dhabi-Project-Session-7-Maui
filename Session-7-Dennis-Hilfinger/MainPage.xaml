<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Session_7_Dennis_Hilfinger.MainPage"
             Title="">

    <VerticalStackLayout>
        <ScrollView
            HorizontalOptions="Center"
            Margin="0, 5, 0, 30">
            <VerticalStackLayout
                HorizontalOptions="Center"
                Spacing="50">
                <Image
                    Source="logo.png"
                    HorizontalOptions="End"
                    Margin="0, 30, 0, 0"/>

                <Button
                    HorizontalOptions="Fill"
                    Margin="30, 0, 30, 0"
                    HeightRequest="60"
                    Text="Search Flights"
                    Clicked="GoToSearch"/>

                <Button
                    HorizontalOptions="Fill"
                    Margin="30, 0, 30, 0"
                    HeightRequest="60"
                    Text="Reserve Seat"
                    Clicked="GoToReserve"/>

                <Button
                    HorizontalOptions="Fill"
                    Margin="30, 0, 30, 0"
                    HeightRequest="60"
                    Text="Amenities"
                    Clicked="GoToAmenities"/>

                <Button
                    HorizontalOptions="Fill"
                    Margin="30, 0, 30, 0"
                    HeightRequest="60"
                    Text="About Our Airline"
                    Clicked="GoToAbout"/>
            </VerticalStackLayout>
        </ScrollView>
    </VerticalStackLayout>


</ContentPage>
